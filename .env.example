# FERIA_SHARED_SECRET: Clave HMAC compartida con SASE para verificar firma del token handoff.
# Si no se define, el servidor no verifica la firma (modo demo local).
FERIA_SHARED_SECRET=

# FERIA_SESSION_SECRET: Clave para encriptar la cookie de sesión HttpOnly.
# Si no se define, se usa FERIA_SHARED_SECRET como fallback.
# Sin ninguna de las dos, la cookie no se encripta correctamente (modo demo).
FERIA_SESSION_SECRET=

# VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY: Proyecto Supabase compartido SASE.
# Solo necesario para feedback institucional. Sin ellas, feedback usa localStorage fallback.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# APP_URL: URL pública donde está desplegada la app.
APP_URL=
