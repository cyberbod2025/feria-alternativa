# FERIA_SHARED_SECRET: clave HMAC compartida con SASE para verificar firma del token handoff.
# Produccion: requerido. Si no se define, el backend responde mode=demo.
FERIA_SHARED_SECRET=

# FERIA_SESSION_SECRET: clave para cifrar la cookie HttpOnly de sesion.
# Si no se define, se usa FERIA_SHARED_SECRET como fallback.
FERIA_SESSION_SECRET=

# VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY: proyecto Supabase compartido SASE.
# Solo necesario para feedback institucional. Sin ellas, feedback usa fallback local.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# APP_URL: URL publica donde esta desplegada la app.
APP_URL=
